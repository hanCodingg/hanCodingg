#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/spi_master.h"
#include "driver/gpio.h"
#include "esp_lcd_panel_io.h"
#include "esp_lcd_panel_vendor.h"
#include "esp_lcd_panel_ops.h"
#include "esp_lcd_st7735.h"
#include "esp_check.h"
#include "esp_log.h"

#define LCD_HOST       SPI2_HOST

#define PIN_SCLK       GPIO_NUM_12
#define PIN_MOSI       GPIO_NUM_11
#define PIN_CS         GPIO_NUM_10
#define PIN_DC         GPIO_NUM_8
#define PIN_RST        GPIO_NUM_9
#define PIN_BL         GPIO_NUM_7

#define LCD_H_RES      160
#define LCD_V_RES      80

#define SPI_CLOCK      (40 * 1000 * 1000)

static const char *TAG = "LCD";

esp_lcd_panel_io_handle_t io_handle = NULL;
esp_lcd_panel_handle_t panel_handle = NULL;

static void lcd_init(void)
{
    // SPI bus
    spi_bus_config_t buscfg = {
        .sclk_io_num = PIN_SCLK,
        .mosi_io_num = PIN_MOSI,
        .miso_io_num = -1,
        .max_transfer_sz = LCD_H_RES * 40 * sizeof(uint16_t),
    };
    ESP_ERROR_CHECK(spi_bus_initialize(LCD_HOST, &buscfg, SPI_DMA_CH_AUTO));

    // Panel IO
    esp_lcd_panel_io_spi_config_t io_cfg = {
        .dc_gpio_num = PIN_DC,
        .cs_gpio_num = PIN_CS,
        .pclk_hz = SPI_CLOCK,
        .lcd_cmd_bits = 8,
        .lcd_param_bits = 8,
        .spi_mode = 0,
        .trans_queue_depth = 10,
    };
    ESP_ERROR_CHECK(esp_lcd_new_panel_io_spi((esp_lcd_spi_bus_handle_t)LCD_HOST,
                                             &io_cfg, &io_handle));

    // Panel
    esp_lcd_panel_dev_config_t panel_cfg = {
        .reset_gpio_num = PIN_RST,
        .rgb_ele_order = LCD_RGB_ELEMENT_ORDER_BGR,
        .bits_per_pixel = 16,
    };

    ESP_ERROR_CHECK(esp_lcd_new_panel_st7735(io_handle, &panel_cfg, &panel_handle));

    ESP_ERROR_CHECK(esp_lcd_panel_reset(panel_handle));
    ESP_ERROR_CHECK(esp_lcd_panel_init(panel_handle));

    // ✅ IMPORTANT for 160×80 mini
    ESP_ERROR_CHECK(esp_lcd_panel_set_gap(panel_handle, 26, 1));

    // ✅ Common for this module
    ESP_ERROR_CHECK(esp_lcd_panel_invert_color(panel_handle, true));

    ESP_ERROR_CHECK(esp_lcd_panel_disp_on_off(panel_handle, true));

    // Backlight
    gpio_config_t bk = {
        .mode = GPIO_MODE_OUTPUT,
        .pin_bit_mask = 1ULL << PIN_BL
    };
    ESP_ERROR_CHECK(gpio_config(&bk));
    gpio_set_level(PIN_BL, 1);

    ESP_LOGI(TAG, "LCD ready");
}

#include "lvgl.h"
#include "esp_timer.h"
#include "sys/lock.h"

static _lock_t lvgl_lock;
static lv_display_t *disp;

// Flush ready callback
static bool lvgl_flush_ready_cb(esp_lcd_panel_io_handle_t io,
                                esp_lcd_panel_io_event_data_t *edata,
                                void *user_ctx)
{
    lv_display_t *d = (lv_display_t *)user_ctx;
    lv_display_flush_ready(d);
    return false;
}

// Flush function
static void lvgl_flush_cb(lv_display_t *disp,
                          const lv_area_t *area,
                          uint8_t *px_map)
{
    esp_lcd_panel_handle_t panel = lv_display_get_user_data(disp);

    int x1 = area->x1;
    int y1 = area->y1;
    int x2 = area->x2;
    int y2 = area->y2;

    // Swap RGB565 bytes if needed
    lv_draw_sw_rgb565_swap(px_map, (x2 - x1 + 1) * (y2 - y1 + 1));

    esp_lcd_panel_draw_bitmap(panel, x1, y1, x2 + 1, y2 + 1, px_map);
}

static void lvgl_tick(void *arg)
{
    lv_tick_inc(2);
}

static void lvgl_task(void *arg)
{
    while (1) {
        _lock_acquire(&lvgl_lock);
        uint32_t delay = lv_timer_handler();
        _lock_release(&lvgl_lock);

        if (delay < 1) delay = 1;
        vTaskDelay(pdMS_TO_TICKS(delay));   // ✅ CORRECT
    }
}

static void ui_init(void)
{
    lv_obj_set_style_bg_color(lv_screen_active(),
                              lv_color_hex(0x003a57), 0);

    lv_obj_t *label = lv_label_create(lv_screen_active());
    lv_label_set_text(label, "Hello PCI");
    lv_obj_set_style_text_color(label, lv_color_hex(0xFFFFFF), 0);

    lv_obj_align(label, LV_ALIGN_CENTER, 0, 0);
}

void app_main(void)
{
    lcd_init();

    lv_init();

    // Create LVGL display
    disp = lv_display_create(LCD_H_RES, LCD_V_RES);

    // Buffers (DMA safe)
    size_t buf_size = LCD_H_RES * 20 * sizeof(lv_color16_t);

    void *buf1 = heap_caps_malloc(buf_size, MALLOC_CAP_DMA);
    void *buf2 = heap_caps_malloc(buf_size, MALLOC_CAP_DMA);

    assert(buf1 && buf2);

    lv_display_set_buffers(disp, buf1, buf2,
                           buf_size, LV_DISPLAY_RENDER_MODE_PARTIAL);

    lv_display_set_user_data(disp, panel_handle);
    lv_display_set_color_format(disp, LV_COLOR_FORMAT_RGB565);
    lv_display_set_flush_cb(disp, lvgl_flush_cb);

    // Register flush done callback
    esp_lcd_panel_io_callbacks_t cbs = {
        .on_color_trans_done = lvgl_flush_ready_cb,
    };
    esp_lcd_panel_io_register_event_callbacks(io_handle, &cbs, disp);

    // LVGL tick timer
    const esp_timer_create_args_t tick_cfg = {
        .callback = lvgl_tick,
        .name = "lv_tick"
    };
    esp_timer_handle_t timer;
    esp_timer_create(&tick_cfg, &timer);
    esp_timer_start_periodic(timer, 2000); // 2 ms

    // Create UI
    _lock_acquire(&lvgl_lock);
    ui_init();
    _lock_release(&lvgl_lock);

    // Start LVGL task
    xTaskCreate(lvgl_task, "lvgl", 4096, NULL, 2, NULL);
}
