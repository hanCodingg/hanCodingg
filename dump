/*
 * LVGL Hello World - ESP32-S3 + ST7735s (80x160)
 * Integrates LVGL 9.x with the ST7735 LCD driver via ESP-IDF SPI stack.
 *
 * LVGL 9 display API changes vs v8:
 *   - lv_disp_drv_t / lv_disp_draw_buf_t removed
 *   - Use lv_display_create() + lv_display_set_buffers() + lv_display_set_flush_cb()
 *   - Flush callback signature: (lv_display_t*, const lv_area_t*, uint8_t*)
 *   - lv_disp_flush_ready()  →  lv_display_flush_ready()
 *   - lv_disp_get_scr_act()  →  lv_screen_active()
 */

#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_err.h"
#include "esp_log.h"
#include "esp_timer.h"
#include "driver/gpio.h"
#include "driver/spi_master.h"
#include "esp_lcd_panel_io.h"
#include "esp_lcd_panel_vendor.h"
#include "esp_lcd_panel_ops.h"
#include "esp_check.h"
#include "esp_lcd_st7735.h"
#include "lvgl.h"

/* ── LCD Dimensions ──────────────────────────────────────────────────────── */
#define LCD_H_RES           (80)
#define LCD_V_RES           (160)

/* ── SPI Configuration ───────────────────────────────────────────────────── */
#define LCD_SPI_NUM         (SPI2_HOST)
#define LCD_PIXEL_CLK_HZ    (40 * 1000 * 1000)
#define LCD_CMD_BITS        (8)
#define LCD_PARAM_BITS      (8)
#define LCD_BITS_PER_PIXEL  (16)
#define LCD_BL_ON_LEVEL     (1)

/* ── Pin Definitions ─────────────────────────────────────────────────────── */
#define LCD_GPIO_SCLK       (GPIO_NUM_12)
#define LCD_GPIO_MOSI       (GPIO_NUM_11)
#define LCD_GPIO_RST        (GPIO_NUM_9)
#define LCD_GPIO_DC         (GPIO_NUM_8)
#define LCD_GPIO_CS         (GPIO_NUM_10)
#define LCD_GPIO_BL         (GPIO_NUM_7)

/* ── LVGL Configuration ──────────────────────────────────────────────────── */
// Buffer height in lines. 20 lines × 160px × 2 bytes = 6.4 KB per buffer.
// Double-buffered so LVGL can render while DMA is transferring the other.
#define LVGL_BUF_LINES      (20)
#define LVGL_TICK_PERIOD_MS (2)
#define LVGL_TASK_STACK_KB  (6 * 1024)
#define LVGL_TASK_PRIORITY  (2)

static const char *TAG = "LCD_LVGL";

static esp_lcd_panel_io_handle_t lcd_io    = NULL;
static esp_lcd_panel_handle_t    lcd_panel = NULL;

static lv_display_t *lvgl_disp  = NULL;
static uint8_t      *lvgl_buf1  = NULL;
static uint8_t      *lvgl_buf2  = NULL;


/* ── LVGL Flush Callback ─────────────────────────────────────────────────── */
/*
 * LVGL 9: signature is (lv_display_t*, const lv_area_t*, uint8_t*).
 * The panel handle is stored via lv_display_set_user_data().
 */
static void lvgl_flush_cb(lv_display_t *disp, const lv_area_t *area, uint8_t *px_map)
{
    esp_lcd_panel_handle_t panel = (esp_lcd_panel_handle_t)lv_display_get_user_data(disp);

    // x2+1 / y2+1 because esp_lcd uses exclusive end coordinates
    esp_lcd_panel_draw_bitmap(panel,
                              area->x1, area->y1,
                              area->x2 + 1, area->y2 + 1,
                              px_map);

    // Tell LVGL the flush is done so it can reuse the buffer
    lv_display_flush_ready(disp);
}


/* ── LVGL Tick Timer ─────────────────────────────────────────────────────── */
/*
 * LVGL needs a periodic tick to track animation timing, debounce, etc.
 * We use an esp_timer (hardware timer) at 2 ms for accuracy.
 */
static void lvgl_tick_cb(void *arg)
{
    lv_tick_inc(LVGL_TICK_PERIOD_MS);
}


/* ── LVGL Handler Task ───────────────────────────────────────────────────── */
/*
 * lv_timer_handler() drives all LVGL internal timers and triggers redraws.
 * Runs in its own task; 10 ms polling gives ~100 fps headroom for this display.
 *
 * NOTE: If you add touch input or call LVGL APIs from other tasks, protect
 *       lv_timer_handler() and all LVGL calls with a mutex.
 */
static void lvgl_task(void *arg)
{
    ESP_LOGI(TAG, "LVGL handler task started");
    while (1) {
        lv_timer_handler();
        vTaskDelay(pdMS_TO_TICKS(10));
    }
}


/* ── LCD Hardware Init ───────────────────────────────────────────────────── */
static esp_err_t lcd_backlight_init(void)
{
    gpio_config_t cfg = {
        .mode         = GPIO_MODE_OUTPUT,
        .pin_bit_mask = 1ULL << LCD_GPIO_BL,
    };
    return gpio_config(&cfg);
}

static esp_err_t lcd_spi_bus_init(void)
{
    const spi_bus_config_t buscfg = {
        .sclk_io_num     = LCD_GPIO_SCLK,
        .mosi_io_num     = LCD_GPIO_MOSI,
        .miso_io_num     = GPIO_NUM_NC,
        .quadwp_io_num   = GPIO_NUM_NC,
        .quadhd_io_num   = GPIO_NUM_NC,
        // Max transfer = full frame; DMA handles it in chunks automatically
        .max_transfer_sz = LCD_H_RES * LCD_V_RES * sizeof(uint16_t),
    };
    return spi_bus_initialize(LCD_SPI_NUM, &buscfg, SPI_DMA_CH_AUTO);
}

static esp_err_t lcd_init(void)
{
    esp_err_t ret = ESP_OK;

    ESP_GOTO_ON_ERROR(lcd_backlight_init(), err, TAG, "Backlight GPIO init failed");
    ESP_GOTO_ON_ERROR(lcd_spi_bus_init(),   err, TAG, "SPI bus init failed");

    const esp_lcd_panel_io_spi_config_t io_cfg = {
        .dc_gpio_num       = LCD_GPIO_DC,
        .cs_gpio_num       = LCD_GPIO_CS,
        .pclk_hz           = LCD_PIXEL_CLK_HZ,
        .lcd_cmd_bits      = LCD_CMD_BITS,
        .lcd_param_bits    = LCD_PARAM_BITS,
        .spi_mode          = 0,
        .trans_queue_depth = 10,
    };
    ESP_GOTO_ON_ERROR(
        esp_lcd_new_panel_io_spi((esp_lcd_spi_bus_handle_t)LCD_SPI_NUM, &io_cfg, &lcd_io),
        err, TAG, "Panel IO init failed");

    const esp_lcd_panel_dev_config_t panel_cfg = {
        .reset_gpio_num = LCD_GPIO_RST,
        .data_endian    = LCD_RGB_ELEMENT_ORDER_BGR,
        .bits_per_pixel = LCD_BITS_PER_PIXEL,
    };
    ESP_GOTO_ON_ERROR(
        esp_lcd_new_panel_st7735(lcd_io, &panel_cfg, &lcd_panel),
        err, TAG, "ST7735 driver init failed");

    ESP_GOTO_ON_ERROR(esp_lcd_panel_reset(lcd_panel),               err, TAG, "Reset failed");
    ESP_GOTO_ON_ERROR(esp_lcd_panel_init(lcd_panel),                err, TAG, "Panel init failed");
    // ESP_GOTO_ON_ERROR(esp_lcd_panel_swap_xy(lcd_panel, true),       err, TAG, "Swap XY failed");
    // ESP_GOTO_ON_ERROR(esp_lcd_panel_mirror(lcd_panel, true, false),err, TAG, "Swap XY failed");
    ESP_GOTO_ON_ERROR(esp_lcd_panel_set_gap(lcd_panel, 2, 3),       err, TAG, "Set gap failed");
    ESP_GOTO_ON_ERROR(esp_lcd_panel_invert_color(lcd_panel, true),  err, TAG, "Invert color failed");
    ESP_GOTO_ON_ERROR(esp_lcd_panel_disp_on_off(lcd_panel, true),   err, TAG, "Display on failed");

    vTaskDelay(pdMS_TO_TICKS(100));
    ESP_GOTO_ON_ERROR(gpio_set_level(LCD_GPIO_BL, LCD_BL_ON_LEVEL), err, TAG, "Backlight on failed");

    ESP_LOGI(TAG, "ST7735 LCD init OK");
    return ret;

err:
    if (lcd_panel) { esp_lcd_panel_del(lcd_panel);    lcd_panel = NULL; }
    if (lcd_io)    { esp_lcd_panel_io_del(lcd_io);    lcd_io    = NULL; }
    spi_bus_free(LCD_SPI_NUM);
    ESP_LOGE(TAG, "LCD init failed: %s", esp_err_to_name(ret));
    return ret;
}


/* ── LVGL Init ───────────────────────────────────────────────────────────── */
static void lvgl_init(void)
{
    lv_init();

    // Allocate DMA-capable draw buffers for zero-copy SPI transfers.
    // LVGL 9 buffers are uint8_t; size = lines × width × bytes-per-pixel.
    const size_t buf_bytes = LCD_H_RES * LVGL_BUF_LINES * sizeof(lv_color_t);
    lvgl_buf1 = heap_caps_malloc(buf_bytes, MALLOC_CAP_DMA);
    lvgl_buf2 = heap_caps_malloc(buf_bytes, MALLOC_CAP_DMA);
    assert(lvgl_buf1 && lvgl_buf2 && "LVGL buffer alloc failed – not enough DMA RAM");

    // LVGL 9: create display object, then attach buffers and flush callback
    lvgl_disp = lv_display_create(LCD_H_RES, LCD_V_RES);
    lv_display_set_buffers(lvgl_disp, lvgl_buf1, lvgl_buf2,
                           buf_bytes, LV_DISPLAY_RENDER_MODE_PARTIAL);
    lv_display_set_flush_cb(lvgl_disp, lvgl_flush_cb);
    lv_display_set_user_data(lvgl_disp, lcd_panel); // forwarded to flush_cb
    lv_display_set_color_format(lvgl_disp, LV_COLOR_FORMAT_RGB565_SWAPPED);

    // Hardware tick timer – more accurate than vTaskDelay-based ticking
    const esp_timer_create_args_t tick_timer_cfg = {
        .callback = lvgl_tick_cb,
        .name     = "lvgl_tick",
    };
    esp_timer_handle_t tick_timer;
    ESP_ERROR_CHECK(esp_timer_create(&tick_timer_cfg, &tick_timer));
    ESP_ERROR_CHECK(esp_timer_start_periodic(tick_timer, LVGL_TICK_PERIOD_MS * 1000));

    // Dedicated task for lv_timer_handler()
    xTaskCreate(lvgl_task, "lvgl", LVGL_TASK_STACK_KB, NULL, LVGL_TASK_PRIORITY, NULL);

    ESP_LOGI(TAG, "LVGL init OK  (buf: 2 × %u bytes, DMA)", (unsigned)buf_bytes);
}


/* ── UI ──────────────────────────────────────────────────────────────────── */
static void ui_create(void)
{
    // LVGL 9: lv_screen_active() replaces lv_disp_get_scr_act(NULL)
    lv_obj_t *scr = lv_screen_active();

    // Dark background
    lv_obj_set_style_bg_color(scr, lv_color_hex(0x1A1A2E), LV_PART_MAIN);
    // lv_obj_set_style_bg_opa(scr, LV_OPA_COVER, LV_PART_MAIN);

    // "Hello World!" label, centred
    lv_obj_t *label = lv_label_create(scr);
    lv_label_set_text(label, "Hello!");
    lv_obj_set_style_text_color(label, lv_color_hex(0x00D4FF), LV_PART_MAIN);
    lv_obj_align(label, LV_ALIGN_CENTER, 0, 0);
}


/* ── Entry Point ─────────────────────────────────────────────────────────── */
void app_main(void)
{
    ESP_ERROR_CHECK(lcd_init());
    lvgl_init();
    ui_create();

    // app_main can now idle; all work is in the LVGL task + tick timer
    while (1) {
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}
